# Ignore data files, large binaries, and secrets

# OpenClaw workspace state (auto-managed, not source)
data-intelligence-architect/
.openclaw/

# Stats tool outputs (large)
*.jasp
*.RData
*.rds
*.Rhistory
*.Rproj.user/

# Python artifacts
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Temporary / scratch
*.tmp
*.bak
*.log

# Build artifacts
*.html
!**.md

